# CorpSim Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/corpsim

# Server
PORT=3004
NODE_ENV=development

# Game Config
PHASE_TIMEOUT_AGENDA=600000      # 10 minutes
PHASE_TIMEOUT_DEBATE=900000      # 15 minutes
PHASE_TIMEOUT_VOTING=300000      # 5 minutes
MAX_QUARTERS=4
ENABLE_AI_SUBSTITUTE=true

# Railway specific
RAILWAY_ENVIRONMENT=production
